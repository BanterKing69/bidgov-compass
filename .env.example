# Copy to .env for local dev.  DO NOT commit .env with real values.

# Required in production — flask session signing.
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production

# Set to 1 in production over HTTPS so session cookies are Secure-only.
SESSION_COOKIE_SECURE=0

# Optional: unlocks Claude-powered NL chat.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: enables the Sell2Wales HTML fallback.
# FIRECRAWL_API_KEY=fc-...
